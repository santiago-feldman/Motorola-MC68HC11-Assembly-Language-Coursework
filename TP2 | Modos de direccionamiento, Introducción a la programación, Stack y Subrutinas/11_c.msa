        p68h11                  ;Declara microprocesador


****************************************************************************************
*                                     MAIN PROGRAM                                     *
*     :La finalidad de éste programa es poder encender los leds de los                 *
*     bits 3 al 6 de forma que se enciendan y apaguen (con 0,5 segundos de tiempo entre*
*     encendido y apagado de leds) de derecha a izquierda de forma ordenanda.          *
****************************************************************************************
        org     $4000           ;Empieza mi programa en una posicicón de memoria

inicio  ldaa    #APAGO          ;carga el valor al puerto de los leds para apagarlos
        staa    $1000           ;durante medio segundo
        jsr     delay           ;realiza la espera de medio segundo
        ldab    #varia          ;inicia contador
        stab    $4100           ;pasa el contador a una posición de memoria

loop    aslb                    ;desplaza el valor un bit hacia la izquierda
        stab    $4150           ;guarda el valor en una posicion de memoria de forma que
        oraa    $4150           ;con una operación ir aumenta el valor en el puerto de leds
        staa    $1000           ;para encender dichos leds
        jsr     delay           ;realiza la espera de medio segundo

        dec     $4100           ;decrementa el contador en 1
        bne     loop            ;Si no es 0 el contador se repite la secuencia anterior
        beq     inicio          ;si es 0 vuelve a repetir el programa entero
fin     jmp     fin             ;se termina el programa


*******************************************************************************
*     ÁREA DE LA SUBRUTINA: Aqui se desarrolla la subrutina que genera un     *
*     delay de 0,5 segundos entre cada secuencia                              *
*******************************************************************************
delay   org     $3000
        psha
        pshb                    ;se hace un backup de los registros a modificar
        pshx

        ldx     #$0005          ;crea el contador mayor
countl  dex
        beq     endsrt1         ;si es cero el contador mayor va a terminar la subrutina

        ldaa    #$FF            ;si no es cero reinicia el contador mediano
countm  deca
        beq     countl          ;si es cero el contador mediano pasa a decrementar el mayor

        ldab    #$C3            ;si no es cero reinicia el contador menor
counts  decb
        bne     counts
        jmp     countm          ;si es cero el contador menor decrementa el mediano

endsrt1 pulx
        pulb                    ;se recuperan los valores guardados
        pula
        rts
        rts
*******************************************************************************************
*                                     ÁREA DEL STACK:                                     *
*     Se reverva espacio del stack con un margen extra                                    *
*******************************************************************************************
        org     $8000
stack   rmb     30
stackP  EQU     * -1
        lds     #stackP


*******************************************************************************
*                               ÁREA DE DATOS:                                *
*     Aquí se presentan los datos a usar en el programa                       *
*******************************************************************************

APAGO   EQU     0
varia   EQU     00000100b


        end
