        p68h11

        org     $3000
        ldx     #$2070          ;se apunta el registro x a la dirección deseada
        clrb
loop    ldaa    0,x
        incb                    ;se aumenta el contador de caracteres
        cmpb    #$00            ;si se llega a 255 caracteres y ninguno contiene CR guarda un 0
        beq     store           ;pues no existe una cadena menor de 256 caracteres que contenga CR
        cmpa    #$0D            ;se fija si el caracter que esta leyendo es CR
        beq     store           ;si es CR pasa a guardar la longitud de la cadena
        inx                     ;si no es pasa al siguiente
        jmp     loop
store   stab    $2000
fin     jmp     fin

        END
