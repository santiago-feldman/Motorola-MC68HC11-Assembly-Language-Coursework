        p68H11                  ;declara el tipo de microprocesador
        org     $2210
        ldab    #4              ;inicia el contador de rotación
        stab    $2209           ;paso el contador a esa posición de memoria
        ldaa    $2200           ;carga el número a dividir
        ldab    $2200           ;carga el número a dividir
mascara EQU     00001111b       ;se usa para hacer AND con los nibbles
        anda    #mascara        ;deja sólo el nibble menos significativo y completa con 0s
repito  rorb                    ;roto el nibble más significativo a la parte del menos
        dec     $2209           ;decremento el contador
        bne     repito          ;si no es 0 el contador vuelvo a rotar el número
        andb    #mascara        ;deja sólo el nibble más significativo y completa con 0s
        staa    $2203           ;guarda el nibble menos significativo
        stab    $2202           ;guarda el nibble más significativo
fin     jmp     fin
        END
